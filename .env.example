# Public app URL used for Stripe redirects and canonical links.
APP_URL="https://www.vibefello.com"

# Public site URL used for metadata and SEO assets.
VITE_SITE_URL="https://www.vibefello.com"

# Stripe production keys
STRIPE_SECRET_KEY="sk_live_xxx"
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_FOUNDING_MEMBER_PRICE_ID="price_live_xxx"
STRIPE_STATEMENT_DESCRIPTOR_SUFFIX="VIBEFELLO"

# Resend transactional email configuration
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="VibeFello <feedback@vibefello.com>"

# Supabase production credentials for server-side API access
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role_xxx"

# Admin dashboard token (used by /admin.html and /api/admin-*)
ADMIN_TOKEN="replace_with_strong_random_token"
